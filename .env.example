# OpenAI Configuration
# OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI Configuration
# AZURE_OPENAI_KEY=your_azure_openai_key_here
# Compatibility alias also supported: AZURE_OPENAI_API_KEY
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name

# Azure AI Foundry Configuration
# AZURE_AI_FOUNDRY_API_KEY=your_azure_ai_foundry_key_here
# AZURE_AI_FOUNDRY_ENDPOINT=https://your-endpoint.inference.ai.azure.com
# AZURE_AI_FOUNDRY_MODEL=your_model_name

# Google Gemini Configuration
# GOOGLE_API_KEY=your_google_api_key_here
# Optional: model id for google-genai (default gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude Configuration
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Alibaba Qwen Configuration
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# QWEN_API_KEY=your_qwen_api_key_here

# Optional: UI Configuration
# LEXORA_UI_PORT=8502
# LEXORA_UI_OUTPUT_DIR=./outputs
