<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX 3.11 — minimal per-machine MSI wrapping the PyInstaller / flet pack output.
  Build (from repo root, after dist/LexoraAI.exe exists):
    candle -arch x64 -dSourceDir=dist -dProductVersion=0.1.1.0 -out build-wix/ packaging/windows/Product.wxs
    light -out LexoraAI-windows-amd64.msi build-wix/Product.wixobj
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="Lexora AI"
      Language="1033"
      Version="$(var.ProductVersion)"
      Manufacturer="Lexora Labs"
      UpgradeCode="cf2de8a4-5c1a-4f8b-9d2e-1a2b3c4d5e6f">
    <Package
        InstallerVersion="200"
        Compressed="yes"
        InstallScope="perMachine"
        Description="Lexora AI desktop application" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Lexora AI is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Feature Id="MainApplication" Title="Lexora AI" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="LexoraLabs">
          <Directory Id="AppFolder" Name="Lexora AI" />
        </Directory>
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="AppFolder">
      <Component Id="cmp_LexoraAIExe" Guid="*">
        <File Id="fil_LexoraAIExe" Source="$(var.SourceDir)\LexoraAI.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
