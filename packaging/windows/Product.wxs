<?xml version="1.0" encoding="UTF-8"?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
    Id="*"
    Name="Lexora AI"
    Manufacturer="Lexora Labs"
    Language="1033"
    Version="$(var.ProductVersion)"
    UpgradeCode="cf2de8a4-5c1a-4f8b-9d2e-1a2b3c4d5e6f">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!--
      Installer UI

      WixUI_FeatureTree exposes the "Custom Setup" feature-selection dialog
      so users can opt in/out of the Start Menu and Desktop shortcuts.

      Note: do NOT set <Property Id="ALLUSERS" .../> here. The
      InstallScope="perMachine" attribute on <Package> already injects
      ALLUSERS=1 and an explicit declaration produces WiX LGHT0091
      "Duplicate symbol 'Property:ALLUSERS'".
    -->
    <Property Id="INSTALLLEVEL" Value="1"/>
    <UIRef Id="WixUI_FeatureTree"/>
    <UIRef Id="WixUI_ErrorProgressText"/>

    <Feature
      Id="MainFeature"
      Title="Lexora AI"
      Description="Lexora AI desktop application."
      Level="1"
      Display="expand"
      Absent="disallow"
      ConfigurableDirectory="APPLICATIONFOLDER">
      <!--
        LexoraComponents is generated at build time by heat.exe from the
        onedir PyInstaller output (dist\LexoraAI\). It includes
        LexoraAI.exe plus every file under _internal\.
      -->
      <ComponentGroupRef Id="LexoraComponents"/>

      <Feature
        Id="StartMenuShortcutFeature"
        Title="Start menu shortcut"
        Description="Create a Start menu shortcut for Lexora AI."
        Level="1"
        Absent="allow"
        InstallDefault="local">
        <ComponentRef Id="StartMenuShortcut"/>
      </Feature>

      <Feature
        Id="DesktopShortcutFeature"
        Title="Desktop shortcut"
        Description="Create a desktop shortcut for Lexora AI."
        Level="1"
        Absent="allow"
        InstallDefault="local">
        <ComponentRef Id="DesktopShortcut"/>
      </Feature>
    </Feature>

    <!-- Add icon to Apps & Features -->
    <Property Id="ARPPRODUCTICON" Value="lexoraico"/>
    <Icon Id="lexoraico" SourceFile="lexora-ai-icon.ico"/>
    <!--
      Icon used by the shortcuts themselves. SourceDir is passed to candle
      as -dSourceDir=dist\LexoraAI so this resolves to the main EXE inside
      the onedir output.
    -->
    <Icon Id="LexoraAI.exe" SourceFile="$(var.SourceDir)\LexoraAI.exe"/>

  </Product>

  <!-- Directories -->
  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="COMPANYFOLDER" Name="Lexora Labs">
          <Directory Id="APPLICATIONFOLDER" Name="Lexora AI"/>
        </Directory>
      </Directory>

      <!--
        Per-machine Start Menu folder (resolves to All Users start menu
        because ALLUSERS=1 / InstallScope=perMachine).
      -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="StartMenuDir" Name="Lexora AI"/>
      </Directory>

      <!--
        CommonDesktopFolder = all-users desktop (per-machine install).
        DesktopFolder is per-user and does NOT receive shortcuts reliably
        when the installer runs elevated.
      -->
      <Directory Id="CommonDesktopFolder"/>
    </Directory>
  </Fragment>

  <!-- Shortcut components -->
  <Fragment>
    <!--
      Start Menu shortcut.

      KeyPath MUST be in HKLM (not HKCU) because this is a perMachine
      install. Using HKCU as KeyPath caused the previous installer to skip
      creating shortcuts even when the user selected them in the feature
      tree: Windows Installer treats per-user KeyPaths as "not applicable"
      during an elevated install and drops the component.
    -->
    <Component Id="StartMenuShortcut" Directory="StartMenuDir" Guid="*">
      <Shortcut
        Id="StartMenuShortcut"
        Name="Lexora AI"
        Description="Launch Lexora AI"
        Target="[APPLICATIONFOLDER]LexoraAI.exe"
        WorkingDirectory="APPLICATIONFOLDER"
        Icon="LexoraAI.exe"
        Advertise="no"/>

      <RemoveFolder Id="RemoveStartMenuDir" Directory="StartMenuDir" On="uninstall"/>
      <RegistryValue Root="HKLM"
                     Key="Software\LexoraLabs\LexoraAI\Shortcuts"
                     Name="StartMenu"
                     Type="integer"
                     Value="1"
                     KeyPath="yes"/>
    </Component>

    <!-- Desktop shortcut (all users). -->
    <Component Id="DesktopShortcut" Directory="CommonDesktopFolder" Guid="*">
      <Shortcut
        Id="DesktopShortcut"
        Name="Lexora AI"
        Description="Launch Lexora AI"
        Target="[APPLICATIONFOLDER]LexoraAI.exe"
        WorkingDirectory="APPLICATIONFOLDER"
        Icon="LexoraAI.exe"
        Advertise="no"/>

      <RegistryValue Root="HKLM"
                     Key="Software\LexoraLabs\LexoraAI\Shortcuts"
                     Name="Desktop"
                     Type="integer"
                     Value="1"
                     KeyPath="yes"/>
    </Component>

  </Fragment>

</Wix>
