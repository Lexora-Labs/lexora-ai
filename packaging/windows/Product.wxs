<?xml version="1.0" encoding="UTF-8"?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
    Id="*"
    Name="Lexora AI"
    Manufacturer="Lexora Labs"
    Language="1033"
    Version="$(var.ProductVersion)"
    UpgradeCode="cf2de8a4-5c1a-4f8b-9d2e-1a2b3c4d5e6f">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Installer UI -->
    <!-- Required by WixUI_Advanced -->
    <Property Id="ALLUSERS" Value="1"/>
    <Property Id="WixAppFolder" Value="WixPerMachineFolder"/>
    <Property Id="INSTALLLEVEL" Value="1"/>
    <WixVariable Id="WixUISupportPerUser" Value="0"/>
    <UIRef Id="WixUI_Advanced"/>
    <UIRef Id="WixUI_ErrorProgressText"/>

    <Feature
      Id="MainFeature"
      Title="Lexora AI"
      Description="Lexora AI desktop application."
      Level="1"
      Display="expand"
      Absent="disallow"
      ConfigurableDirectory="APPLICATIONFOLDER">
      <ComponentRef Id="MainExe"/>
      <Feature
        Id="StartMenuShortcutFeature"
        Title="Start menu shortcut"
        Description="Create a Start menu shortcut for Lexora AI."
        Level="1"
        Absent="allow"
        InstallDefault="local">
        <ComponentRef Id="StartMenuShortcut"/>
      </Feature>
      <Feature
        Id="DesktopShortcutFeature"
        Title="Desktop shortcut"
        Description="Create a desktop shortcut for Lexora AI."
        Level="32767"
        Absent="allow"
        InstallDefault="local">
        <ComponentRef Id="DesktopShortcut"/>
      </Feature>
    </Feature>

    <!-- Add icon to Apps & Features -->
    <Property Id="ARPPRODUCTICON" Value="lexora-ai-icon.ico"/>
    <Icon Id="lexora-ai-icon.ico" SourceFile="lexora-ai-icon.ico"/>
    <Icon Id="LexoraAI.exe" SourceFile="$(var.SourceDir)\LexoraAI.exe"/>

  </Product>

  <!-- Directories -->
  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="COMPANYFOLDER" Name="Lexora Labs">
          <Directory Id="APPLICATIONFOLDER" Name="Lexora AI"/>
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="StartMenuDir" Name="Lexora AI"/>
      </Directory>

      <Directory Id="DesktopFolder"/>
    </Directory>
  </Fragment>

  <!-- Components -->
  <Fragment>
    <Component Id="MainExe" Directory="APPLICATIONFOLDER" Guid="*">
      <File Id="LexoraExe"
            Source="$(var.SourceDir)\LexoraAI.exe"
            KeyPath="yes"/>
    </Component>

    <!-- Start Menu Shortcut -->
    <Component Id="StartMenuShortcut" Directory="StartMenuDir" Guid="*">
      <Shortcut
        Id="StartMenuShortcut"
        Name="Lexora AI"
        Target="[#LexoraExe]"
        WorkingDirectory="APPLICATIONFOLDER"
        Icon="LexoraAI.exe"
        Advertise="no"/>

      <RemoveFolder Id="RemoveStartMenuDir" Directory="StartMenuDir" On="uninstall"/>
      <RegistryValue Root="HKCU"
                     Key="Software\LexoraLabs\LexoraAI"
                     Name="StartMenuShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes"/>
    </Component>

    <!-- Desktop Shortcut -->
    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="*">
      <Shortcut
        Id="DesktopShortcut"
        Name="Lexora AI"
        Target="[#LexoraExe]"
        WorkingDirectory="APPLICATIONFOLDER"
        Icon="LexoraAI.exe"
        Advertise="no"/>

      <RegistryValue Root="HKCU"
                     Key="Software\LexoraLabs\LexoraAI"
                     Name="DesktopShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes"/>
    </Component>

  </Fragment>

</Wix>
